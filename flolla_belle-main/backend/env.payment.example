# Copy relevant lines into backend/.env or backend/src/.env
# Rwanda e-commerce: MTN MoMo (momodeveloper.mtn.com) + Airtel (developers.airtel.africa)

# --- Local / staging (no real USSD) ---
PAYMENT_MODE=simulate
PAYMENT_SIMULATE_SECRET=change-me-dev-only

# After POST /api/payments/initiate in simulate mode, mark paid with:
# curl -X POST http://localhost:4000/api/payments/simulate-complete/ORD-5 \
#   -H "X-Payment-Simulate-Secret: change-me-dev-only"

# --- MTN MoMo Collection (production / sandbox from MTN portal) ---
# MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# MTN_MOMO_SUBSCRIPTION_KEY=
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_TARGET_ENV=sandbox
# MTN_MOMO_CURRENCY=RWF

# --- Airtel Money (verify exact collection URL in your Airtel dashboard) ---
# AIRTEL_BASE_URL=https://openapiuat.airtel.africa
# AIRTEL_CLIENT_ID=
# AIRTEL_CLIENT_SECRET=
# AIRTEL_COUNTRY=RW
# AIRTEL_CURRENCY=RWF
